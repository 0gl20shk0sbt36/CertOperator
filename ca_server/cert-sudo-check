#!/bin/bash
# =============================================================================
# cert-sudo-check — 检查 SSH 证书是否包含 sudo-access principal
# 通过 PAM pam_exec.so 调用
# exit 0 = 允许 sudo，exit 1 = 拒绝
#
# v2: 增加 /tmp/ssh-*/agent.* 扫描，不依赖 SSH_AUTH_SOCK 环境变量
#     （PAM 环境下 SSH_AUTH_SOCK 不可用）
# =============================================================================
set -euo pipefail

# ---- 配置（可通过环境变量覆盖） ----
CA_PUB_FILE="${CERT_SUDO_CA:-/opt/ca_server/data/ca_key.pub}"
SUDO_EXT="${CERT_SUDO_EXT:-sudo@cert-operator}"

# ---- 查找 SSH agent socket ----
find_agent_sock() {
    # 1. 优先用环境变量
    if [[ -n "${SSH_AUTH_SOCK:-}" ]] && [[ -S "$SSH_AUTH_SOCK" ]]; then
        echo "$SSH_AUTH_SOCK"
        return 0
    fi

    # 2. 扫描 /tmp/ssh-*/agent.* 寻找当前用户的 socket
    for d in /tmp/ssh-*/agent.*; do
        [[ -S "$d" ]] || continue
        if [[ "$(stat -c '%u' "$d" 2>/dev/null)" == "$(id -u)" ]]; then
            echo "$d"
            return 0
        fi
    done

    return 1
}

# ---- 获取 CA 公钥指纹 ----
get_ca_fp() {
    if [[ ! -f "$CA_PUB_FILE" ]]; then
        return 1
    fi
    ssh-keygen -lf "$CA_PUB_FILE" 2>/dev/null | awk '{print $2}'
}

# ---- 检查证书列表 ----
check_certs() {
    local sock="$1" ca_fp="$2"

    CERT_DATA=$(SSH_AUTH_SOCK="$sock" ssh-add -L 2>/dev/null) || return 1
    [[ -z "$CERT_DATA" ]] && return 1

    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        echo "$line" | grep -q "cert-v01@openssh.com" || continue

        TMP=$(mktemp)
        echo "$line" > "$TMP"
        INFO=$(ssh-keygen -L -f "$TMP" 2>/dev/null || true)
        rm -f "$TMP"
        [[ -z "$INFO" ]] && continue

        if echo "$INFO" | grep -q "$ca_fp"; then
            if echo "$INFO" | grep -q "$SUDO_EXT"; then
                return 0
            fi
        fi
    done <<< "$CERT_DATA"

    return 1
}

# ---- Main ----
SOCK=$(find_agent_sock) || exit 1
CA_FP=$(get_ca_fp) || exit 1
check_certs "$SOCK" "$CA_FP" && exit 0 || exit 1
