#!/bin/bash
# =============================================================================
# cert-sudo-check — 检查当前 SSH 会话是否有 sudo@cert-operator 扩展
# 通过 PAM pam_exec.so 调用，exit 0 = 允许 sudo，exit 1 = 拒绝
#
# v7: 通过进程树找到 SSH_AUTH_SOCK（不受 sudo -n/PAM env 限制）
#     不从 /tmp 扫描 stale socket，避免假阳性
# =============================================================================
set -u

CA_PUB_FILE="${CERT_SUDO_CA:-/opt/ca_server/data/ca_key.pub}"
SUDO_EXT="${CERT_SUDO_EXT:-sudo@cert-operator}"

get_ca_fp() {
    [[ -f "$CA_PUB_FILE" ]] || return 1
    ssh-keygen -lf "$CA_PUB_FILE" 2>/dev/null | awk '{print $2}'
}

# 通过进程树找 SSH_AUTH_SOCK（从 sshd 进程环境读）
find_ssh_sock() {
    local pid="$1" p cp child max=20
    cp=$pid; child=""
    for ((i=0; i<max; i++)); do
        local name
        name=$(cat /proc/$cp/comm 2>/dev/null) || break
        if [[ "$name" == "sshd" ]]; then
            # sshd 的子进程（用户 shell）的环境中有 SSH_AUTH_SOCK
            local sock
            sock=$(cat /proc/$child/environ 2>/dev/null | tr '\0' '\n' | grep '^SSH_AUTH_SOCK=' | tail -1 | cut -d= -f2-)
            if [[ -n "$sock" && -S "$sock" ]]; then
                echo "$sock"
                return 0
            fi
            # fallback: sshd 进程本身
            sock=$(cat /proc/$cp/environ 2>/dev/null | tr '\0' '\n' | grep '^SSH_AUTH_SOCK=' | tail -1 | cut -d= -f2-)
            if [[ -n "$sock" && -S "$sock" ]]; then
                echo "$sock"
                return 0
            fi
        fi
        p=$(cat /proc/$cp/status 2>/dev/null | awk '/^PPid:/{print $2}') || break
        [[ -z "$p" || "$p" == "0" ]] && break
        child=$cp
        cp=$p
    done
    return 1
}

check_sock() {
    local sock="$1" ca_fp="$2" data line tmp
    set +e
    data=$(SSH_AUTH_SOCK="$sock" ssh-add -L 2>/dev/null)
    [[ $? -ne 0 || -z "$data" ]] && return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" ]] && continue
        echo "$line" | grep -q "cert-v01@openssh.com" || continue
        tmp=$(mktemp) || continue
        echo "$line" > "$tmp"
        local info
        info=$(ssh-keygen -L -f "$tmp" 2>/dev/null)
        rm -f "$tmp"
        [[ -z "$info" ]] && continue
        echo "$info" | grep -q "$ca_fp" || continue
        echo "$info" | grep -q "$SUDO_EXT" && return 0
    done <<< "$data"
    return 1
}

# ---- Main ----
CA_FP=$(get_ca_fp) || exit 1

SOCK=$(find_ssh_sock "$$") || exit 1
check_sock "$SOCK" "$CA_FP" && exit 0
exit 1
