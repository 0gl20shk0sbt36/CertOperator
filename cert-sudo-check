#!/bin/bash
# =============================================================================
# cert-sudo-check — 检查当前会话是否有 sudo@cert-operator 扩展的 SSH 证书
# 通过 PAM 的 pam_exec.so 调用，exit 0 = 允许 sudo，exit 1 = 拒绝
#
# v4: 修复 set -e 在 agent 检查失败后被意外中断的问题
#     check_agent_certs() 内部不再因 set -e 退出整个脚本
# =============================================================================
set -u

CA_PUB_FILE="${CERT_SUDO_CA:-/opt/ca_server/data/ca_key.pub}"
SUDO_EXT="${CERT_SUDO_EXT:-sudo@cert-operator}"

get_ca_fp() {
    if [[ ! -f "$CA_PUB_FILE" ]]; then
        return 1
    fi
    ssh-keygen -lf "$CA_PUB_FILE" 2>/dev/null | awk '{print $2}'
}

check_cert_file() {
    local cert_path="$1" ca_fp="$2"
    [[ -f "$cert_path" ]] || return 1
    local info
    info=$(ssh-keygen -L -f "$cert_path" 2>/dev/null) || return 1
    [[ -z "$info" ]] && return 1
    echo "$info" | grep -q "$ca_fp" || return 1
    echo "$info" | grep -q "$SUDO_EXT" || return 1
    return 0
}

scan_cert_files() {
    local ca_fp="$1" f
    for f in "$HOME"/.ssh/*-cert.pub "$HOME"/.hermes/certs/*-cert.pub; do
        [[ -f "$f" ]] || continue
        check_cert_file "$f" "$ca_fp" && return 0
    done
    return 1
}

find_agent_sock() {
    [[ -n "${SSH_AUTH_SOCK:-}" ]] && [[ -S "$SSH_AUTH_SOCK" ]] && { echo "$SSH_AUTH_SOCK"; return 0; }
    local d
    for d in /tmp/ssh-*/agent.*; do
        [[ -S "$d" ]] || continue
        [[ "$(stat -c '%u' "$d" 2>/dev/null)" == "$(id -u)" ]] || continue
        echo "$d"
        return 0
    done
    return 1
}

check_agent_certs() {
    local sock="$1" ca_fp="$2" data line tmp info
    set +e
    data=$(SSH_AUTH_SOCK="$sock" ssh-add -L 2>/dev/null)
    if [[ $? -ne 0 || -z "$data" ]]; then
        return 1
    fi
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" ]] && continue
        echo "$line" | grep -q "cert-v01@openssh.com" || continue
        tmp=$(mktemp) || continue
        echo "$line" > "$tmp"
        info=$(ssh-keygen -L -f "$tmp" 2>/dev/null)
        rm -f "$tmp"
        [[ -z "$info" ]] && continue
        if echo "$info" | grep -q "$ca_fp" && echo "$info" | grep -q "$SUDO_EXT"; then
            return 0
        fi
    done <<< "$data"
    return 1
}

# ---- Main ----
CA_FP=$(get_ca_fp) || exit 1

SOCK=$(find_agent_sock) || true
if [[ -n "$SOCK" ]]; then
    check_agent_certs "$SOCK" "$CA_FP" && exit 0
fi

scan_cert_files "$CA_FP" && exit 0
exit 1
